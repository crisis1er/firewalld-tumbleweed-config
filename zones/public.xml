<?xml version="1.0" encoding="utf-8"?>
<zone target="DROP">
  <short>Public</short>
  <description>For use in public areas. You do not trust the other computers on networks to not harm your computer. Only selected incoming connections are accepted.</description>
  <service name="dhcpv6-client"/>
  <service name="https"/>
  <service name="http"/>
  <service name="squid"/>
  <service name="dns"/>
  <service name="dhcp"/>
  <service name="kdeconnect"/>
  <service name="dns-over-tls"/>
  <service name="samba-client"/>
  <service name="ws-discovery"/>
  <port port="8000-8001" protocol="tcp"/>
  <port port="8000-8001" protocol="udp"/>
  <port port="854" protocol="tcp"/>
  <port port="6881-6889" protocol="tcp"/>
  <port port="6881-6889" protocol="udp"/>
  <port port="2019" protocol="tcp"/>
  <port port="8053" protocol="tcp"/>
  <port port="10000" protocol="tcp"/>
  <port port="443" protocol="udp"/>
  <port port="51413" protocol="tcp"/>
  <port port="51413" protocol="udp"/>
  <!-- ports radio (qmmp/KDE) supprimés — ouverts à la demande via alias zsh radio-on/radio-off -->
  <interface name="br0"/>
  <forward/>
</zone>
